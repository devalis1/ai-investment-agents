NEXT_PUBLIC_SUPABASE_URL=your_supabase_url

# Client-safe API key from Supabase Dashboard > Project Settings > API (Publishable / sb_publishable_...).
# Supabase Next.js + @supabase/ssr examples use this name:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_sb_publishable_key
# Optional: same key, for snippets that still say NEXT_PUBLIC_SUPABASE_ANON_KEY:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_sb_publishable_key

# LLM provider (local-first recommended)
OPENAI_API_KEY=your_openai_key

# Supabase server-side access (do not expose to the browser)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Local inference (Ollama / LM Studio)
LLM_LOCAL_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:latest
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# TODO: Replace with the exact model id/name shown in LM Studio.
LMSTUDIO_MODEL=

# Cloud fallback (optional). Disabled by default.
ENABLE_CLOUD_FALLBACK=false

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# HTTP cycle worker (apps/backend `npm run cycle:trigger-server`) — rotate a long random string; same value as Vercel server env on the frontend project
# CYCLE_TRIGGER_SECRET=
# CYCLE_TRIGGER_SERVER_PORT=8787

# Frontend-only (set in Vercel / apps/frontend .env.local — server-side, not NEXT_PUBLIC_)
# CYCLE_TRIGGER_URL=https://your-worker-host.example.com/
# CYCLE_TRIGGER_PROXY_TIMEOUT_MS=240000

