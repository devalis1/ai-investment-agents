# Copy to `.env.local` at the MONOREPO ROOT (`ai-investment-agents/.env.local`).
# Frontend: run `cd apps/frontend && npm run dev` — `scripts/run-with-root-env.mjs` loads root `.env` / `.env.local` before Next (do not use raw `npx next dev` if vars are root-only).

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url

# Client-safe key: Supabase Dashboard > Project Settings > API (Publishable / sb_publishable_...).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_sb_publishable_key
# Optional: same value; frontend accepts this name if the line above is empty (see lib/supabase/client.ts).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-side (never expose to the browser)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Verbose LLM request/response logging (default off). Set to "true" only when debugging.
LLM_DEBUG=false

# Local inference (Ollama / LM Studio) — default path for `npm run dev:cycle`
LLM_LOCAL_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:latest
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Required when LLM_LOCAL_PROVIDER=lmstudio — use the model id shown in LM Studio.
LMSTUDIO_MODEL=

# Cloud fallback (GitHub Actions daily cycle, or local when local LLM is unavailable).
# When ENABLE_CLOUD_FALLBACK=true, GEMINI_API_KEY is required.
ENABLE_CLOUD_FALLBACK=false
GEMINI_API_KEY=
# Use an id from https://ai.google.dev/gemini-api/docs/models (e.g. gemini-2.5-flash). Older ids may 404 for new API keys.
GEMINI_MODEL=gemini-2.5-flash

# Yahoo Finance (flaky residential / IPv6): optional `query1.finance.yahoo.com`; per-request timeout ms (5k–120k, default 60k).
# Backend fetch uses Undici + IPv4-only DNS by default (`YAHOO_FETCH_IPV4_ONLY`, set to "false" to allow dual-stack).
# YAHOO_FINANCE_QUERY_HOST=query1.finance.yahoo.com
# YAHOO_FETCH_TIMEOUT_MS=90000
# YAHOO_FETCH_IPV4_ONLY=true
# Optional: NODE_OPTIONS=--dns-result-order=ipv4first (apps/backend also calls dns.setDefaultResultOrder("ipv4first") in fetcher/networkDefaults.ts).
#
# Offline / broken Yahoo: `FETCH_MARKET_DATA_MODE=dev_stub` reads `data/dev-market-stub.json` (copy from apps/backend/data/dev-market-stub.example.json). Override path with FETCH_DEV_STUB_PATH.
# FETCH_MARKET_DATA_MODE=yahoo
# FETCH_DEV_STUB_PATH=data/dev-market-stub.json
# Or keep Yahoo but use stub only after price/RSI retries fail:
# FETCH_MARKET_DATA_FALLBACK=dev_stub

# Cycle ticker list when public.tickers has no enabled rows (or DB read fails). Comma-separated.
# CLI / scheduled job only; HTTP trigger worker uses JSON body tickers.
TICKERS=AAPL,MSFT,NVDA

# Per-cycle wall clock guard inside analyzeCycle (ms). Default in code: 1800000 (30m).
# CYCLE_HARD_TIMEOUT_MS=1800000

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# HTTP cycle worker: apps/backend `npm run cycle:trigger-server`
# Same secret as Vercel server env on the frontend app.
# CYCLE_TRIGGER_SECRET=
# CYCLE_TRIGGER_SERVER_PORT=8787
# On PaaS, PORT may be set instead of CYCLE_TRIGGER_SERVER_PORT.

# Frontend server-only (Vercel / apps/frontend `.env.local`): proxy to the worker
# CYCLE_TRIGGER_URL=https://your-worker-host.example.com/
# CYCLE_TRIGGER_SECRET=same-as-worker
# CYCLE_TRIGGER_PROXY_TIMEOUT_MS=240000

# Dashboard: protects POST/PATCH/DELETE on `apps/frontend` `/api/tickers` (edits `public.tickers`).
# Generate a long random string. Put the same value in the dashboard “DB edits” field (sessionStorage).
TICKERS_ADMIN_SECRET=replace_with_a_long_random_string
